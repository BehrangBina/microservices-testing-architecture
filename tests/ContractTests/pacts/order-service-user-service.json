{
  "consumer": {
    "name": "order-service"
  },
  "interactions": [
    {
      "description": "a request for a non-existent user",
      "pending": false,
      "request": {
        "method": "GET",
        "path": "/users/99999999-9999-9999-9999-999999999999"
      },
      "response": {
        "status": 404
      },
      "type": "Synchronous/HTTP"
    },
    {
      "description": "a request to get a user by id",
      "pending": false,
      "request": {
        "method": "GET",
        "path": "/users/11111111-1111-1111-1111-111111111111"
      },
      "response": {
        "body": {
          "content": {
            "createdAt": "2024-01-01T00:00:00Z",
            "email": "alice@example.com",
            "id": "11111111-1111-1111-1111-111111111111",
            "name": "Alice"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json; charset=utf-8"
          ]
        },
        "matchingRules": {
          "body": {
            "$.createdAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[^@]+@[^@]+\\.[^@]+$"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pactRust": {
      "ffi": "0.4.27",
      "models": "1.2.8"
    },
    "pactSpecification": {
      "version": "4.0"
    }
  },
  "provider": {
    "name": "user-service"
  }
}